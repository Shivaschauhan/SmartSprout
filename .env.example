# Database Connection
# Local Development (SQLite): sqlite:///./smartsprout.db
# Production (PostgreSQL): postgresql://username:password@hostname:port/database_name
DATABASE_URL=sqlite:///./smartsprout.db

# JWT Auth Security Configuration
# Generate a secure secret using: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
